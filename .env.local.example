# ─────────────────────────────────────────────────────────────────
#  BOSS — Environment Variables
#  Copy this file to .env.local and fill in your real values.
#  NEVER commit .env.local to git — it contains secret keys.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Paystack ──────────────────────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys & Webhooks
# Use TEST keys during development, LIVE keys for production
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_SECRET_KEY=sk_test_YOUR_PAYSTACK_SECRET_KEY

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production set this to your real Vercel URL e.g.:
# NEXT_PUBLIC_APP_URL=https://boss-africa.vercel.app

# ── Invoice security token (generate any random string) ───────────
BOSS_INVOICE_TOKEN=YOUR_RANDOM_SECRET_STRING

# ── Google OAuth (required for sign-in) ───────────────────────────
# Supabase dashboard → Authentication → Providers → Enable Google
#   → Client ID + Client Secret from Google Cloud Console
# Supabase dashboard → Authentication → URL Configuration
#   → Site URL: https://your-app.vercel.app
#   → Redirect URLs: add /auth/callback
# Google Cloud Console → OAuth 2.0 → Authorised redirect URIs
#   → Add: https://[PROJECT_REF].supabase.co/auth/v1/callback
